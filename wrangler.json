{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "skyqimen",
  "pages_build_output_dir": "dist",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "skyqimen-db",
      "database_id": "REPLACE_WITH_YOUR_D1_DATABASE_ID"
    }
  ],
  "compatibility_date": "2024-03-01",
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
